# Per-instance overrides. Copy as .env.instance and edit.
# Used with: docker compose --env-file .env --env-file .env.instance up -d

# Compose project name. Prefixes all containers/volumes/networks.
# Must be unique per instance on the host.
COMPOSE_PROJECT_NAME=osm-db-repair

# Traefik router name. Lowercase, no dots. Unique per instance.
INSTANCE_NAME=db-repair

# Public hostname. Traefik routes traffic on this host to web:3000.
# nip.io pattern: <slug>.<host-ip-with-dashes>.nip.io
INSTANCE_HOST=db-repair.204-168-242-139.nip.io
